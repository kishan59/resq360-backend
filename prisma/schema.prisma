generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS (Strict Operational Categories) ---

enum Role {
  OWNER
  TEAM_MEMBER
}

enum EncounterStatus {
  PENDING_SHELTER_INTAKE
  TREATED_ON_SITE
  MERGED_TO_PATIENT
}

enum CageZone {
  DANGER
  MEDIUM
  MINOR
  FREE_ROAMING
}

enum Temperament {
  CALM
  VIOLENT
}

enum PatientStatus {
  IN_SHELTER
  AT_EXTERNAL_VET
  RELEASED
  DECEASED
}

enum VetTripStatus {
  PENDING_APPROVAL
  APPROVED
  COMPLETED
}

// --- MODELS ---

model User {
  id                 String             @id @default(uuid())
  name               String
  phone_number       String             @unique // NEW: For logging in
  password           String             // NEW: We will hash this securely
  role               Role               @default(TEAM_MEMBER)
  
  encounters         Encounter[]        
  medical_logs       MedicalLog[]       
  inventory_arrivals InventoryArrival[] 
  vet_trips          VetTrip[]          @relation("RequestedBy")
  audit_logs         AuditLog[]         @relation("AuditActor")
  
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
}

model Reporter {
  id           String      @id @default(uuid())
  name         String?
  phone_number String?
  phone_e164   String?     @unique
  is_anonymous Boolean     @default(false)
  
  encounters   Encounter[] 
  
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
}

model Encounter {
  id                     String          @id @default(uuid())
  status                 EncounterStatus @default(PENDING_SHELTER_INTAKE)
  
  // FIRST ACTIONS ON SCENE
  initial_media_url      String          // The photo/video taken from a safe distance
  initial_media_is_video Boolean         @default(false)
  pickup_lat             Float           // Captured exactly when the media is taken
  pickup_lon             Float
  pickup_accuracy_m      Float?
  pickup_captured_at     DateTime?
  
  // SECONDARY ACTIONS
  initial_audio_url      String?         // The voice-to-text / raw audio log
  qr_code_id             String?         // Attempted ONLY if animal is calm enough
  
  created_by_id          String
  created_by             User            @relation(fields: [created_by_id], references: [id])
  
  reporter_id            String?
  reporter               Reporter?       @relation(fields: [reporter_id], references: [id])
  
  patient                Patient?        // Linked if brought to the shelter
  
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  deleted_at             DateTime?
}

model Patient {
  id            String        @id @default(uuid())
  qr_code_id    String?       @unique // Inherited from Encounter, OR scanned safely in cage
  temperament   Temperament?
  cage_zone     CageZone?
  status        PatientStatus @default(IN_SHELTER)
  
  encounter_id  String        @unique
  encounter     Encounter     @relation(fields: [encounter_id], references: [id])
  
  medical_logs  MedicalLog[]
  vet_trips     VetTrip[]
  media         PatientMedia[]
  
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  deleted_at    DateTime?
}

model PatientMedia {
  id         String   @id @default(uuid())
  patient_id String
  patient    Patient  @relation(fields: [patient_id], references: [id])
  
  media_url  String
  is_video   Boolean  @default(false)
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model MedicalLog {
  id               String   @id @default(uuid())
  patient_id       String
  patient          Patient  @relation(fields: [patient_id], references: [id])
  
  logged_by_id     String
  user             User     @relation(fields: [logged_by_id], references: [id])
  
  audio_log_url    String   // The primary data point for employees
  text_translation String?  @db.Text // Optional SaaS toggle feature
  is_vet_update    Boolean  @default(false) // Was this recorded at an external hospital?
  
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  deleted_at       DateTime?
}

model VetTrip {
  id               String        @id @default(uuid())
  patient_id       String
  patient          Patient       @relation(fields: [patient_id], references: [id])
  
  requested_by_id  String
  requester        User          @relation("RequestedBy", fields: [requested_by_id], references: [id])
  
  status           VetTripStatus @default(PENDING_APPROVAL)
  scheduled_date   DateTime?
  
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
}

model InventoryArrival {
  id            String   @id @default(uuid())
  item_name     String
  quantity      Int
  unit_type     String?  // e.g., "boxes", "bottles"
  
  logged_by_id  String
  user          User     @relation(fields: [logged_by_id], references: [id])
  
  arrived_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

// The Admin's Master Switchboard
model AppSettings {
  id                  Int      @id @default(1) // We only ever need one row of settings
  input_level         Int      @default(1) 
  allow_video_uploads Boolean  @default(false) // Admin turns this on when they buy storage
  updated_at          DateTime @updatedAt
}

model SyncMutation {
  id                 String   @id @default(uuid())
  client_mutation_id String   @unique
  device_id          String
  entity_type        String
  entity_id          String?
  operation          String
  status             String
  resolution         String?
  conflict_fields    Json?
  response_json      Json?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  actor_id    String?
  actor       User?    @relation("AuditActor", fields: [actor_id], references: [id])
  entity_type String
  entity_id   String
  action      String
  before_json Json?
  after_json  Json?
  created_at  DateTime @default(now())
}